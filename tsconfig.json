{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./"
  },
  "ts-node": {
    "transpileOnly": true
  },
  "include": ["./hardhat.config.ts", "./scripts/**/*.ts", "./test/**/*.ts", "./ignition/**/*.ts"],
  "exclude": ["./frontend", "node_modules", "./dist"]
}
