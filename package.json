{
  "name": "erc20-dex",
  "version": "1.0.0",
  "description": "ERC20 DEX Smart Contracts",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "coverage": "hardhat coverage",
    "lint": "prettier --check \"contracts/**/*.sol\"",
    "lint:fix": "prettier --write \"contracts/**/*.sol\"",
    "deploy:local": "hardhat ignition deploy ignition/modules/main.ts --network localhost",
    "deploy:sepolia": "hardhat ignition deploy ignition/modules/main.ts --network sepolia --verify",
    "node": "hardhat node",
    "sync-abis": "npx ts-node scripts/sync-abis.ts",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:test": "cd frontend && npm run test",
    "install:all": "npm install && cd frontend && npm install",
    "audit": "npm audit --audit-level=moderate",
    "slither": "slither . --solc-remaps '@openzeppelin=node_modules/@openzeppelin' --exclude-dependencies"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.0.0",
    "chai": "^4.3.0",
    "dotenv": "^16.0.0",
    "ethers": "^6.0.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.8",
    "mocha": "^10.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-solidity": "^1.3.0",
    "solidity-coverage": "^0.8.0",
    "ts-node": "^10.9.0",
    "typechain": "^8.3.2",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}

